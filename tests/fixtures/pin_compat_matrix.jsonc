// PinType 兼容矩阵的权威合约。
//
// Rust 端 PinType::is_compatible_with（在 crates/core/src/pin.rs）与前端
// TS 端 isCompatibleWith（在 web/src/lib/pin-compat.ts）都必须与本文件一致。
// 任意一方漂移 → 合约测试 CI 红。
//
// 修改本文件时同步检查上述两份实现，且**必须**跑：
//   cargo test -p nazh-core --test pin_compat_contract
//   npm --prefix web run test pin-compat
//
// 序列化形态：PinType 是 tagged union（discriminator 字段为 `kind`，全小写
// 变体名）：
//   { "kind": "any" }
//   { "kind": "bool" }
//   { "kind": "array", "inner": <PinType> }     // 递归嵌套
//   { "kind": "custom", "name": "modbus-register" }
//
// 覆盖纪律：每个新增 PinType 变体最少补 3 条配对——
//   (1) 自反兼容
//   (2) 与 Any 双向兼容
//   (3) 与至少一个其他类型不兼容

{
  "pairs": [
    // ===== 标量自反兼容 =====
    { "from": { "kind": "any" },     "to": { "kind": "any" },     "compatible": true },
    { "from": { "kind": "bool" },    "to": { "kind": "bool" },    "compatible": true },
    { "from": { "kind": "integer" }, "to": { "kind": "integer" }, "compatible": true },
    { "from": { "kind": "float" },   "to": { "kind": "float" },   "compatible": true },
    { "from": { "kind": "string" },  "to": { "kind": "string" },  "compatible": true },
    { "from": { "kind": "json" },    "to": { "kind": "json" },    "compatible": true },
    { "from": { "kind": "binary" },  "to": { "kind": "binary" },  "compatible": true },

    // ===== Any 双向吃一切 =====
    { "from": { "kind": "any" },    "to": { "kind": "bool" },   "compatible": true },
    { "from": { "kind": "bool" },   "to": { "kind": "any" },    "compatible": true },
    { "from": { "kind": "any" },    "to": { "kind": "json" },   "compatible": true },
    { "from": { "kind": "json" },   "to": { "kind": "any" },    "compatible": true },
    { "from": { "kind": "any" },    "to": { "kind": "string" }, "compatible": true },
    { "from": { "kind": "string" }, "to": { "kind": "any" },    "compatible": true },
    {
      "from": { "kind": "any" },
      "to":   { "kind": "array", "inner": { "kind": "bool" } },
      "compatible": true
    },
    {
      "from": { "kind": "array", "inner": { "kind": "json" } },
      "to":   { "kind": "any" },
      "compatible": true
    },
    {
      "from": { "kind": "any" },
      "to":   { "kind": "custom", "name": "modbus-register" },
      "compatible": true
    },
    {
      "from": { "kind": "custom", "name": "sql-row" },
      "to":   { "kind": "any" },
      "compatible": true
    },

    // ===== 标量跨类型不兼容（无自动数值提升或结构桥接）=====
    // integer/float 不互通避免隐式精度损失；string/json 不互通，
    // 因为 "JSON 字符串" 与 "字符串字面量" 在数据层面是不同形状。
    { "from": { "kind": "bool" },    "to": { "kind": "integer" }, "compatible": false },
    { "from": { "kind": "integer" }, "to": { "kind": "float" },   "compatible": false },
    { "from": { "kind": "float" },   "to": { "kind": "integer" }, "compatible": false },
    { "from": { "kind": "string" },  "to": { "kind": "json" },    "compatible": false },
    { "from": { "kind": "json" },    "to": { "kind": "string" },  "compatible": false },
    { "from": { "kind": "bool" },    "to": { "kind": "json" },    "compatible": false },
    { "from": { "kind": "binary" },  "to": { "kind": "string" },  "compatible": false },

    // ===== Array 嵌套兼容性 =====
    {
      "from": { "kind": "array", "inner": { "kind": "bool" } },
      "to":   { "kind": "array", "inner": { "kind": "bool" } },
      "compatible": true
    },
    {
      "from": { "kind": "array", "inner": { "kind": "bool" } },
      "to":   { "kind": "array", "inner": { "kind": "integer" } },
      "compatible": false
    },
    // 内层 Any 走 Any 双向规则（递归兼容）
    {
      "from": { "kind": "array", "inner": { "kind": "any" } },
      "to":   { "kind": "array", "inner": { "kind": "json" } },
      "compatible": true
    },
    {
      "from": { "kind": "array", "inner": { "kind": "json" } },
      "to":   { "kind": "array", "inner": { "kind": "any" } },
      "compatible": true
    },
    // 数组与标量不互通（即使元素类型相同）
    {
      "from": { "kind": "array", "inner": { "kind": "bool" } },
      "to":   { "kind": "bool" },
      "compatible": false
    },

    // ===== Custom 命名类型严格匹配 =====
    {
      "from": { "kind": "custom", "name": "modbus-register" },
      "to":   { "kind": "custom", "name": "modbus-register" },
      "compatible": true
    },
    {
      "from": { "kind": "custom", "name": "modbus-register" },
      "to":   { "kind": "custom", "name": "sql-row" },
      "compatible": false
    },
    // Custom 不与 Json 自动桥接——避免协议级类型被误连到通用结构。
    // PinType::Custom 的 rustdoc 有详细解释（在 crates/core/src/pin.rs）。
    {
      "from": { "kind": "custom", "name": "modbus-register" },
      "to":   { "kind": "json" },
      "compatible": false
    },
    {
      "from": { "kind": "json" },
      "to":   { "kind": "custom", "name": "modbus-register" },
      "compatible": false
    }
  ]
}
